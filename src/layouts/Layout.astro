---
import fs from 'node:fs';
import path from 'node:path';
import crypto from 'node:crypto';
import { seo, organization, service } from '../data/site.ts';

const base = import.meta.env.BASE_URL;
const styleHash = crypto
  .createHash('md5')
  .update(fs.readFileSync(path.join(process.cwd(), 'public/style.css')))
  .digest('hex')
  .slice(0, 8);

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: organization.name,
  alternateName: organization.alternateName,
  url: organization.url,
  logo: organization.logo,
  image: organization.image,
  telephone: organization.telephone,
  email: organization.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: organization.address.streetAddress,
    addressLocality: organization.address.addressLocality,
    addressCountry: organization.address.addressCountry,
  },
  sameAs: organization.sameAs,
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: service.serviceType,
  name: service.name,
  description: service.description,
  provider: {
    '@type': 'Organization',
    name: organization.name,
    url: organization.url,
  },
  areaServed: {
    '@type': 'Country',
    name: service.areaServed,
  },
  audience: {
    '@type': 'Audience',
    audienceType: service.audienceType,
  },
};
---
<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8" />
<title>{seo.title}</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={seo.description} />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content={seo.themeColor} />
<link rel="canonical" href={seo.canonical} />
<link rel="icon" href={`${base}img/favicon-32.png`} sizes="32x32" type="image/png" />
<link rel="icon" href={`${base}img/favicon-192.png`} sizes="192x192" type="image/png" />
<link rel="apple-touch-icon" href={`${base}img/apple-touch-icon.png`} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content={seo.siteName} />
<meta property="og:locale" content={seo.locale} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.ogDescription} />
<meta property="og:url" content={seo.canonical} />
<!-- TODO: swap for a dedicated 1200×630 OG share image once designed — placeholder reuses the hero product cut-out -->
<meta property="og:image" content={seo.ogImage.url} />
<meta property="og:image:width" content={String(seo.ogImage.width)} />
<meta property="og:image:height" content={String(seo.ogImage.height)} />
<meta property="og:image:type" content={seo.ogImage.type} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.ogDescription} />
<meta name="twitter:image" content={seo.ogImage.url} />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Sora:wght@400;500;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="preload" as="image" href={`${base}img/inverter-cut.png`} fetchpriority="high">
<link href={`${base}style.css?v=${styleHash}`} rel="stylesheet">

<script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
<script type="application/ld+json" set:html={JSON.stringify(serviceLd)} />
</head>
<body>
<slot />
</body>
</html>
